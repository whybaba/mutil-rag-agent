# ============================================================
# Multi-Agent AIOps Platform - .env.example
# ============================================================
# Copy this file to .env and fill in your own keys.
#   copy .env.example .env      (Windows)
#   cp .env.example .env        (Linux/macOS)

# ---- Application ----
APP_NAME=MultiAgentAIOps
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=9900

# ---- LLM (required) ----
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DASHSCOPE_API_KEY=your-dashscope-api-key-here  # optional
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_CHAT_MODEL=deepseek-v4-pro
DASHSCOPE_ROUTER_MODEL=deepseek-v4-flash
AGENT_PLANNER_MODEL=deepseek-v4-flash
AGENT_EXECUTOR_MODEL=deepseek-v4-flash
AGENT_REPORT_MODEL=deepseek-v4-flash

# ---- Embedding ----
EMBEDDING_PROVIDER=ollama
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIM=1024
OLLAMA_BASE_URL=http://host.docker.internal:11434  # 容器内访问宿主机 Ollama
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_EMBEDDING_DIM=1024
OLLAMA_EMBEDDING_BATCH_SIZE=8
OLLAMA_EMBEDDING_TIMEOUT_SEC=120

# ---- Storage (use service names for Docker Compose) ----
MILVUS_HOST=standalone
MILVUS_PORT=19530
MILVUS_COLLECTION=multi_agent_kb
MILVUS_TIMEOUT_MS=10000
REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql://multi_agent:multi_agent@postgres:5432/multi_agent_aiops

# ---- RAG ----
RAG_TOP_K=3
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
RAG_PARENT_MAX_CHARS=2400
KB_ADMIN_TOKEN=change-this-admin-token
RAG_HYBRID_ENABLED=true
RAG_RETRIEVE_K=30
RAG_HYBRID_BM25_WEIGHT=0.4
RAG_RERANK_ENABLED=true
RAG_RERANK_PROVIDER=local
RAG_LOCAL_RERANK_BACKEND=flagembedding
RAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
RAG_LOCAL_RERANK_DEVICE=auto
RAG_LOCAL_RERANK_MAX_LENGTH=512
RAG_LOCAL_RERANK_BATCH_SIZE=8

# ---- RAG chat ----
RAG_CHAT_MEMORY_ENABLED=true
RAG_CHAT_HISTORY_TURNS=3
RAG_CHAT_MEMORY_TTL_SEC=604800
RAG_CHAT_WEB_SEARCH_ENABLED=true
RAG_CHAT_WEB_SEARCH_MAX_RESULTS=3

# ---- Incident pipeline ----
INCIDENT_PIPELINE_ENABLED=true
INCIDENT_QUEUE_PRIORITY_ENABLED=true
DIAGNOSIS_TASK_MAX_ATTEMPTS=3
DIAGNOSIS_TASK_TIMEOUT_SEC=600
MANUAL_DIAGNOSIS_CONCURRENCY=2
WORKER_DIAGNOSIS_CONCURRENCY=2

# ---- MCP endpoints (use service names for Docker Compose) ----
# 如果 MCP 服务未启动，可以注释掉或保持默认
MCP_SYSTEM_URL=http://mcp-system:8005/mcp
MCP_WEBSEARCH_URL=http://mcp-websearch:8006/mcp
MCP_WINLOG_URL=http://mcp-winlog:8008/mcp
MCP_NETWORK_URL=http://mcp-network:8009/mcp
MCP_DOCKER_URL=http://mcp-docker:8011/mcp

# ---- Agent runtime ----
AGENT_MAX_STEPS=5
AGENT_MAX_CONCURRENCY=2
PERMISSION_MODE=normal
GUARDRAILS_BLOCK_HIGH_RISK_TOOLS=true
EXECUTOR_PARALLEL_ENABLED=true
EXECUTOR_MAX_ITERS=4
EXECUTOR_MAX_PARALLEL=6

# ---- Web search ----
WEB_SEARCH_PROVIDER=open_websearch
OPEN_WEBSEARCH_BASE_URL=http://open-websearch:3210
OPEN_WEBSEARCH_ENGINE=bing
OPEN_WEBSEARCH_SEARCH_MODE=auto
OPEN_WEBSEARCH_TIMEOUT_SEC=15

# ---- Local LLM fallback (optional) ----
LOCAL_LLM_ENABLED=false
LOCAL_LLM_FORCE=false
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434/v1
LOCAL_LLM_MODEL=qwen2.5:7b
LOCAL_LLM_API_KEY=ollama

# ---- Logging ----
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_RETENTION_DAYS=14